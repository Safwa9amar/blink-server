# Supabase (project URL + keys from Dashboard → Settings → API)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-or-publishable-key
# Server-only — bypasses RLS. NEVER commit the real value.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Postgres connection for drizzle-kit migrate/pull/studio (not needed for generate).
# Local Supabase:
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
# Cloud Supabase: use the project's session-pooler string (Database settings).

# JWT
JWT_SECRET=your-jwt-secret-min-32-chars-long

# Server
PORT=3000
NODE_ENV=development

# Sub-path the API is mounted under. Empty when served at a domain root.
# On cPanel sub-URI (e.g. greenpedal.net/blink): leave empty first; if
# /blink/health returns 404 after deploy, set BASE_PATH=/blink.
BASE_PATH=

# Required as the `x-cron-secret` header to call POST /library/scrape.
# Generate one with: openssl rand -hex 32. Empty disables the check (dev only).
CRON_SECRET=

# Run the in-process node-cron scheduler. Keep "false" on cPanel/Passenger
# (idle spin-down kills it) — drive scrapes from a cPanel Cron Job instead.
ENABLE_INPROCESS_CRON=false

# Google OAuth (Supabase external provider) — create a Web OAuth client in
# Google Cloud Console; authorized redirect: http://127.0.0.1:54321/auth/v1/callback
SUPABASE_AUTH_GOOGLE_CLIENT_ID=
SUPABASE_AUTH_GOOGLE_SECRET=
